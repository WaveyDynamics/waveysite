---
import Layout from './Layout.astro';
import Hero from '../components/Hero.astro';

interface Props {
  title: string;
  heading: string;
  subheading?: string;
  image?: string;
  imagePosition?: string;
  imageHeight?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  robots?: string;
}

const { title, heading, subheading, image, imagePosition, imageHeight, description, ogImage, canonicalUrl, robots } = Astro.props;
---

<Layout title={title} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} robots={robots}>
  <Hero heading={heading} image={image} imagePosition={imagePosition} imageHeight={imageHeight} />

  {subheading && (
    <div class="max-w-[1030px] mx-auto px-5 md:px-[65px] pt-[15px] pb-[15px]">
      <p class="wd-subheading">{subheading}</p>
      <div class="mt-4 w-[50px] h-[2px] bg-black"></div>
    </div>
  )}

  <article class="px-5 md:px-[65px] pt-12 pb-24 max-w-[1030px] mx-auto">
    <slot />
  </article>
</Layout>
