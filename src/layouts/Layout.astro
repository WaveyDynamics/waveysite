---
import '../styles/global.css';
import SocialIcons from '../components/SocialIcons.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: string;
  robots?: string;
}

const {
  title = "Wavey Dynamics",
  description = "Motorsport engineering, vehicle dynamics and performance development consultancy.",
  ogImage = "https://waveydynamics.com/logo.png",
  canonicalUrl,
  jsonLd,
  robots = 'index, follow',
} = Astro.props;

const canonicalURL = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;

const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Wavey Dynamics",
  "url": "https://waveydynamics.com",
  "logo": "https://waveydynamics.com/logo.png",
  "email": "contact@waveydynamics.com",
  "telephone": "+44-7742-853-965",
  "sameAs": [
    "https://www.instagram.com/waveydynamics",
    "https://www.linkedin.com/company/wavey-dynamics",
    "https://www.youtube.com/channel/UCzlllROxb1ZVulW1zp31rqw"
  ]
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:site_name" content="Wavey Dynamics" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={orgJsonLd} />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-379619503"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-379619503');</script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body>
    <header class="bg-(--color-canvas) border-b border-(--color-border) sticky top-0 z-50">

      <div class="w-full px-5 lg:px-[65px] pt-6 lg:pt-8 pb-6 lg:pb-[55px] grid grid-cols-[1fr_auto_1fr] lg:flex lg:items-start lg:justify-between items-center">
        <div class="lg:hidden"></div>

        <a href="/" class="no-underline">
          <img src="/logo.png" alt="Wavey Dynamics" class="h-12 lg:h-[67px] w-auto" />
        </a>

        <div class="flex justify-end items-center gap-5">
          <div class="hidden lg:flex items-center gap-5">
            <SocialIcons size={17} iconColor="#ffffff" />
          </div>
          <button id="nav-toggle" class="lg:hidden text-white p-1" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      <nav class="hidden lg:block">
        <ul class="w-full px-[65px] pt-[10px] pb-[12px] flex list-none gap-6 items-center text-[13px]">

          <li class="relative group">
            <a href="/about" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors flex items-center gap-1">
              About <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <ul class="absolute top-full left-0 hidden group-hover:block list-none bg-(--color-canvas) border border-(--color-border) min-w-[160px] z-50 py-1">
              <li><a href="/about"    class="wd-nav-drop">About Us</a></li>
              <li><a href="/whatwedo" class="wd-nav-drop">What We Do</a></li>
              <li><a href="/mission"  class="wd-nav-drop">Mission</a></li>
              <li><a href="/news"     class="wd-nav-drop">News</a></li>
            </ul>
          </li>

          <li><a href="/long-days-long-nights" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors">Long Days, Longer Nights</a></li>

          <li class="relative group">
            <a href="/" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors flex items-center gap-1">
              Specialist Consulting <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <ul class="absolute top-full left-0 hidden group-hover:block list-none bg-(--color-canvas) border border-(--color-border) min-w-[180px] z-50 py-1">
              <li><a href="/consulting-motorsport"      class="wd-nav-drop">Motorsport</a></li>
              <li><a href="/consulting-vehicledynamics" class="wd-nav-drop">Vehicle Dynamics</a></li>
              <li><a href="/consulting-aerodynamics"    class="wd-nav-drop">Aerodynamics</a></li>
              <li><a href="/consulting-development"     class="wd-nav-drop">Engineering Development</a></li>
            </ul>
          </li>

          <li><a href="/concierge" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors">Concierge</a></li>

          <li><a href="/research-development" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors">Research &amp; Development</a></li>

          <li class="relative group">
            <a href="/articles" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors flex items-center gap-1">
              Field Notes <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <ul class="absolute top-full left-0 hidden group-hover:block list-none bg-(--color-canvas) border border-(--color-border) min-w-[220px] z-50 py-1">
              <li><a href="/articles" class="wd-nav-drop">All Field Notes</a></li>
              <li><a href="/rce"      class="wd-nav-drop">Racecar Engineering Magazine</a></li>
              <li><a href="/news"     class="wd-nav-drop">News</a></li>
            </ul>
          </li>

          <li class="relative group">
            <a href="/community" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors flex items-center gap-1">
              Community <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <ul class="absolute top-full left-0 hidden group-hover:block list-none bg-(--color-canvas) border border-(--color-border) min-w-[220px] z-50 py-1">
              <li><a href="/online"   class="wd-nav-drop">Wavey Dynamics Online</a></li>
              <li><a href="/podcast"  class="wd-nav-drop">Podcast</a></li>
              <li><a href="/seminars" class="wd-nav-drop">Seminars &amp; Speaking</a></li>
              <li><a href="/outreach" class="wd-nav-drop">Outreach</a></li>
              <li><a href="/rce"      class="wd-nav-drop">Racecar Engineering Magazine</a></li>
            </ul>
          </li>

          <li class="relative group">
            <a href="/learn" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors flex items-center gap-1">
              Learn With Us <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <ul class="absolute top-full left-0 hidden group-hover:block list-none bg-(--color-canvas) border border-(--color-border) min-w-[220px] z-50 py-1">
              <li><a href="/vdfundamentals" class="wd-nav-drop">Vehicle Dynamics Fundamentals</a></li>
            </ul>
          </li>

          <li><a href="/contact" class="no-underline text-(--color-text) hover:text-(--color-accent) transition-colors">Contact</a></li>

        </ul>
      </nav>

    </header>

    <div id="mobile-menu" class="hidden fixed inset-0 z-[999] overflow-y-auto" style="background:#000000;">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#2a2a2a]">
        <a href="/" class="no-underline" id="mobile-logo-link">
          <img src="/logo.png" alt="Wavey Dynamics" class="h-9 w-auto" />
        </a>
        <button id="nav-close" class="text-white p-1" aria-label="Close menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="4" y1="4" x2="20" y2="20"/>
            <line x1="20" y1="4" x2="4" y2="20"/>
          </svg>
        </button>
      </div>

      <nav class="px-5 pb-12 pt-2">
        <div class="border-b border-[#1e1e1e] py-4">
          <p class="wd-mob-label">About</p>
          <a href="/about"    class="wd-mob-link">About Us</a>
          <a href="/whatwedo" class="wd-mob-link">What We Do</a>
          <a href="/mission"  class="wd-mob-link">Mission</a>
          <a href="/news"     class="wd-mob-link">News</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <a href="/long-days-long-nights" class="wd-mob-link wd-mob-primary">Long Days, Longer Nights</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <p class="wd-mob-label">Specialist Consulting</p>
          <a href="/consulting-motorsport"      class="wd-mob-link">Motorsport</a>
          <a href="/consulting-vehicledynamics" class="wd-mob-link">Vehicle Dynamics</a>
          <a href="/consulting-aerodynamics"    class="wd-mob-link">Aerodynamics</a>
          <a href="/consulting-development"     class="wd-mob-link">Engineering Development</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <a href="/concierge"            class="wd-mob-link wd-mob-primary">Concierge</a>
          <a href="/research-development" class="wd-mob-link wd-mob-primary">Research &amp; Development</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <p class="wd-mob-label">Field Notes</p>
          <a href="/articles" class="wd-mob-link">All Field Notes</a>
          <a href="/rce"      class="wd-mob-link">Racecar Engineering Magazine</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <p class="wd-mob-label">Community</p>
          <a href="/online"   class="wd-mob-link">Wavey Dynamics Online</a>
          <a href="/podcast"  class="wd-mob-link">Podcast</a>
          <a href="/seminars" class="wd-mob-link">Seminars &amp; Speaking</a>
          <a href="/outreach" class="wd-mob-link">Outreach</a>
        </div>

        <div class="border-b border-[#1e1e1e] py-4">
          <p class="wd-mob-label">Learn With Us</p>
          <a href="/learn"          class="wd-mob-link">Learn With Us</a>
          <a href="/vdfundamentals" class="wd-mob-link">Vehicle Dynamics Fundamentals</a>
        </div>

        <div class="py-4">
          <a href="/contact" class="wd-mob-link wd-mob-primary">Contact</a>
        </div>

        <div class="flex gap-6 items-center pt-4 border-t border-[#1e1e1e]">
          <SocialIcons size={18} iconColor="#ffffff" />
        </div>
      </nav>
    </div>

    <main class="min-h-[calc(100vh-200px)]">
      <slot />
    </main>

    <footer class="bg-white px-5 lg:px-[65px] py-12 mt-8 text-[12px]">
      <div class="text-center leading-[1.9]">
        <p>contact@waveydynamics.com</p>
        <p>+44 (0) 7742 853 965</p>
        <p>United Kingdom</p>
        <div class="flex justify-center items-center gap-6 my-4">
          <SocialIcons size={15} iconColor="black" />
        </div>
        <p class="mt-6">©2026 Wavey Dynamics Limited.</p>
      </div>
    </footer>

    <div id="wd-lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
      <img id="wd-lightbox-img" src="" alt="" />
    </div>

    <style is:global>
      #wd-lightbox {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,0.92);
        display: none; align-items: center; justify-content: center;
        padding: 24px; cursor: zoom-out;
      }
      #wd-lightbox.is-open { display: flex; }
      #wd-lightbox img { max-width: 100%; max-height: 100%; object-fit: contain; cursor: zoom-out; user-select: none; }
    </style>

    <script>
      const lb  = document.getElementById('wd-lightbox');
      const img = document.getElementById('wd-lightbox-img') as HTMLImageElement | null;
      document.querySelectorAll('main img').forEach(el => {
        if (el.closest('a')) return;
        (el as HTMLElement).style.cursor = 'zoom-in';
        el.addEventListener('click', () => {
          if (!img || !lb) return;
          img.src = (el as HTMLImageElement).src;
          img.alt = el.alt;
          lb.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        });
      });
      function closeLightbox() {
        lb?.classList.remove('is-open');
        document.body.style.overflow = '';
      }
      lb?.addEventListener('click', closeLightbox);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

      const toggle   = document.getElementById('nav-toggle');
      const closeBtn = document.getElementById('nav-close');
      const menu     = document.getElementById('mobile-menu');

      function openMenu() {
        menu?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        toggle?.setAttribute('aria-expanded', 'true');
      }
      function closeMenu() {
        menu?.classList.add('hidden');
        document.body.style.overflow = '';
        toggle?.setAttribute('aria-expanded', 'false');
      }

      toggle?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
    </script>
  </body>
</html>
