---
interface Props {
  label: string;
  body: string;
  image?: string;
  href?: string;
  reverse?: boolean;
}
const { label, body, image, href, reverse = false } = Astro.props;
---

<section class="max-w-[1400px] mx-auto px-4 md:px-8 py-12">
  <div class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-start`}>
    <div class="w-full md:w-[45%] flex-shrink-0">
      <div
        class="relative w-full aspect-[4/3] bg-cover bg-center bg-[#1a1d21]"
        style={image ? `background-image:url('${image}')` : ''}
      >
        <div class="absolute inset-0 bg-black/50"></div>
        <div class={`absolute top-0 ${reverse ? 'left-0' : 'right-0'} bg-white px-2 py-[2px]`}>
          <span class="uppercase tracking-[0.03em] text-black" style="font-family:'Gotham Light',sans-serif;font-size:23px;">{label}</span>
        </div>
      </div>
    </div>
    <div class="w-full md:w-[55%] flex flex-col items-center text-center px-4 md:px-10 py-6">
      <p class="leading-relaxed">{body}</p>
      {href && (
        <a href={href} class="inline-block mt-8 border border-(--color-border) px-6 py-2 text-sm no-underline hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">
          Learn more...
        </a>
      )}
    </div>
  </div>
</section>