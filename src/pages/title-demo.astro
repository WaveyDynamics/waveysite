---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Title Style Demo | Wavey Dynamics" robots="noindex, nofollow">
<div style="max-width:900px;margin:0 auto;padding:60px 65px;">

  <p style="font-family:'Gotham Light',sans-serif;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(0,0,0,0.35);margin-bottom:60px;">
    Demo page — title &amp; sub-section treatment options. Delete after approval.
  </p>

  <!-- ═══════════════════════════════════════════
       SUB-SECTION (H3) OPTIONS
  ══════════════════════════════════════════════ -->
  <div style="margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid rgba(0,0,0,0.08);">
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 40px 0;">Sub-section (H3) Options — shown in context with body text</p>

    <!-- H3 Option 1: Left green stroke -->
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 12px 0;">H3 Option 1 — Left Green Stroke</p>
    <h3 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:15px;line-height:1.4;color:rgba(0,0,0,0.82);margin:0 0 10px 0;border-left:2px solid #19E3C4;padding-left:12px;">Roll Centre Height</h3>
    <p style="font-family:'Gotham Light',sans-serif;font-size:14px;line-height:1.625;color:rgba(0,0,0,0.72);margin:0 0 40px 0;">The roll centre is the theoretical point about which the body rolls relative to the ground. Its height governs the relationship between lateral force and roll moment.</p>

    <!-- H3 Option 2: Green dot prefix -->
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 12px 0;">H3 Option 2 — Accent Dot Prefix</p>
    <h3 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:15px;line-height:1.4;color:rgba(0,0,0,0.82);margin:0 0 10px 0;display:flex;align-items:center;gap:10px;">
      <span style="width:6px;height:6px;background:#19E3C4;flex-shrink:0;display:inline-block;"></span>Roll Centre Height
    </h3>
    <p style="font-family:'Gotham Light',sans-serif;font-size:14px;line-height:1.625;color:rgba(0,0,0,0.72);margin:0 0 40px 0;">The roll centre is the theoretical point about which the body rolls relative to the ground. Its height governs the relationship between lateral force and roll moment.</p>

    <!-- H3 Option 3: Small caps label style -->
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 12px 0;">H3 Option 3 — Small Caps / Label Style</p>
    <h3 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:11px;line-height:1.4;color:#19E3C4;margin:0 0 6px 0;text-transform:uppercase;letter-spacing:0.16em;">Roll Centre Height</h3>
    <p style="font-family:'Gotham Light',sans-serif;font-size:14px;line-height:1.625;color:rgba(0,0,0,0.72);margin:0 0 40px 0;">The roll centre is the theoretical point about which the body rolls relative to the ground. Its height governs the relationship between lateral force and roll moment.</p>
  </div>

  <!-- ═══════════════════════════════════════════
       OPTION A — All caps + short accent rule
  ══════════════════════════════════════════════ -->
  <div style="margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid rgba(0,0,0,0.08);">
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 40px 0;">Option A — All Caps + Accent Rule</p>

    <div style="padding-top:32px;">
      <!-- Short green rule -->
      <div style="width:36px;height:2px;background:#19E3C4;margin-bottom:24px;"></div>
      <!-- Category -->
      <div style="display:flex;gap:14px;margin-bottom:20px;">
        <span style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#19E3C4;">Tech Bites</span>
        <span style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#19E3C4;">Vehicle Dynamics</span>
      </div>
      <!-- Title — uppercase -->
      <h1 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:28px;line-height:1.25;letter-spacing:0.06em;text-transform:uppercase;color:rgba(0,0,0,0.88);margin:0 0 18px 0;">
        Chassis Balance and Vehicle Handling Response
      </h1>
      <!-- Meta -->
      <p style="font-family:'Gotham Light',sans-serif;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(0,0,0,0.38);margin:0;">
        9 May 2020 &ensp;·&ensp; 4 min read
      </p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       OPTION B — Large display + green overline
  ══════════════════════════════════════════════ -->
  <div style="margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid rgba(0,0,0,0.08);">
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 40px 0;">Option B — Large Display + Green Overline</p>

    <div style="padding-top:32px;">
      <!-- Category small label -->
      <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.38);margin:0 0 16px 0;">
        Tech Bites &ensp;/&ensp; Vehicle Dynamics
      </p>
      <!-- Green overline -->
      <div style="width:100%;height:1px;background:#19E3C4;margin-bottom:28px;"></div>
      <!-- Large title -->
      <h1 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:46px;line-height:1.12;letter-spacing:0.01em;color:rgba(0,0,0,0.88);margin:0 0 28px 0;">
        Chassis Balance and Vehicle Handling Response
      </h1>
      <!-- Meta -->
      <p style="font-family:'Gotham Light',sans-serif;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(0,0,0,0.38);margin:0;">
        9 May 2020 &ensp;·&ensp; 4 min read
      </p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       OPTION C — Split-colour first word
  ══════════════════════════════════════════════ -->
  <div style="margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid rgba(0,0,0,0.08);">
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 40px 0;">Option C — Split-Colour First Word</p>

    <div style="padding-top:32px;">
      <!-- Category + date on one line -->
      <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(0,0,0,0.38);margin:0 0 20px 0;">
        <span style="color:#19E3C4;">Tech Bites</span> &ensp;·&ensp; 9 May 2020 &ensp;·&ensp; 4 min read
      </p>
      <!-- Title — first word in accent -->
      <h1 style="font-family:'Gotham Light',sans-serif;font-weight:300;font-size:36px;line-height:1.2;letter-spacing:0.01em;color:rgba(0,0,0,0.88);margin:0 0 24px 0;">
        <span style="color:#19E3C4;">Chassis</span> Balance and Vehicle Handling Response
      </h1>
      <!-- Thin faint rule -->
      <div style="width:100%;height:1px;background:rgba(0,0,0,0.09);"></div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       OPTION D — Mono stamp + heavier weight title
  ══════════════════════════════════════════════ -->
  <div style="margin-bottom:80px;">
    <p style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.3);margin:0 0 40px 0;">Option D — Mono Stamp + Heavier Title</p>

    <div style="padding-top:32px;">
      <!-- Mono stamp line -->
      <p style="font-family:'Courier New',monospace;font-size:11px;letter-spacing:0.08em;color:rgba(0,0,0,0.32);margin:0 0 14px 0;">
        09.05.2020 &nbsp;/&nbsp; TECH BITES &nbsp;/&nbsp; 4 MIN READ
      </p>
      <!-- Accent bar -->
      <div style="width:100%;height:2px;background:#19E3C4;margin-bottom:22px;"></div>
      <!-- Title in Gotham Medium -->
      <h1 style="font-family:'Gotham Medium',sans-serif;font-weight:500;font-size:28px;line-height:1.3;letter-spacing:0.01em;color:rgba(0,0,0,0.88);margin:0 0 18px 0;">
        Chassis Balance and Vehicle Handling Response
      </h1>
      <!-- Category tags below -->
      <div style="display:flex;gap:14px;">
        <span style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#19E3C4;">Tech Bites</span>
        <span style="font-family:'Gotham Light',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:#19E3C4;">Vehicle Dynamics</span>
      </div>
    </div>
  </div>

</div>
</Layout>
