---
import { getCollection } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';

const allPosts = await getCollection('blog', ({ id, data }) => {
  if (id.startsWith('_')) return false;
  return data.categories?.includes('News') ?? false;
});
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<ArticleLayout
  title="News | Wavey Dynamics"
  heading="NEWS"
  subheading="Wavey Dynamics News"
  description="The latest news from Wavey Dynamics — collaborations, new projects, achievements and media features from our motorsport engineering team."
>

  <p class="mb-5 leading-relaxed">Here we will keep you updated with latest news on what we're doing. Collaborations, new projects, achievements and media related content will be regularly posted here.</p>
  <p class="mb-12 leading-relaxed">Our followers and readers are part of our journey, we want to share it with you as we make things happen.</p>

  {posts.length > 0 ? (
    <div class="divide-y divide-gray-200">
      {posts.map((post) => (
        <div class="py-8 first:pt-0">
          <p class="text-[11px] uppercase tracking-widest mb-2" style="color:rgba(0,0,0,0.4);font-family:'Gotham Light',sans-serif;">
            {new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
          <h3 class="text-[16px] leading-snug mb-3" style="font-family:'Gotham Light',sans-serif;font-weight:300;">
            {post.data.title}
          </h3>
          {post.data.excerpt && (
            <p class="text-[13px] leading-relaxed mb-4" style="color:rgba(0,0,0,0.55);">{post.data.excerpt}</p>
          )}
          <a href={`/blog/${post.id}`}
            class="inline-block text-[11px] uppercase tracking-widest no-underline hover:text-(--color-accent) transition-colors"
            style="font-family:'Gotham Light',sans-serif;color:rgba(0,0,0,0.55);">
            Read More →
          </a>
        </div>
      ))}
    </div>
  ) : (
    <p class="leading-relaxed" style="color:rgba(0,0,0,0.4);">News posts will appear here.</p>
  )}

</ArticleLayout>
